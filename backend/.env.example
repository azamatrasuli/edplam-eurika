APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8009
APP_CORS_ORIGINS=http://localhost:5177,http://127.0.0.1:5177,https://my-dev.space

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REQUEST_TIMEOUT_SECONDS=40

# --- Speech (152-ФЗ: отключено для запрета трансграничной передачи аудио) ---
STT_ENABLED=false
TTS_ENABLED=false

RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.3

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/eurika

PORTAL_JWT_SECRET=replace_me          # Общий секрет с порталом (= EURIKA_JWT_SECRET в portal/.env)
PORTAL_JWT_ALGORITHM=HS256
PORTAL_API_URL=                       # URL портала для server-to-server API (пусто = отключено)
PORTAL_INTERNAL_API_KEY=              # API key для /api/internal/* (= INTERNAL_API_KEY в portal/.env)

TELEGRAM_BOT_TOKEN=

EXTERNAL_LINK_SECRET=replace_me
SESSION_SIGNING_SECRET=replace_me

SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- amoCRM ---
AMOCRM_SUBDOMAIN=azamatrasuli
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=
AMOCRM_SALES_PIPELINE_ID=10689842
AMOCRM_SERVICE_PIPELINE_ID=10689990
AMOCRM_TELEGRAM_ID_FIELD=1404988
AMOCRM_PRODUCT_FIELD=1404990
AMOCRM_AMOUNT_FIELD=1404992

# --- amoCRM Sales Pipeline Stages (Корзинолёты) ---
AMOCRM_STAGE_NEW=0
AMOCRM_STAGE_INFO_GATHERING=0
AMOCRM_STAGE_PROPOSAL=0
AMOCRM_STAGE_MANAGER_REVIEW=0
AMOCRM_STAGE_AWAITING_PAYMENT=0
AMOCRM_STAGE_PAID=142
AMOCRM_STAGE_DECLINED=0
AMOCRM_STAGE_ARCHIVE=143

# --- amoCRM Reanimation Pipeline ---
AMOCRM_REANIMATION_PIPELINE_ID=0
AMOCRM_REANIMATION_STAGE_WARMUP=0
AMOCRM_REANIMATION_STAGE_ACTIVE=0

# --- amoCRM Post-Sale Pipeline ---
AMOCRM_POSTSALE_PIPELINE_ID=0
AMOCRM_POSTSALE_STAGE_ACCESS=0
AMOCRM_POSTSALE_STAGE_QUESTIONNAIRE=0
AMOCRM_POSTSALE_STAGE_REGISTRATION=0
AMOCRM_POSTSALE_STAGE_DOCUMENTS=0
AMOCRM_POSTSALE_STAGE_ENROLLED=0

# --- amoCRM Chat API (imBox) ---
AMOCRM_CHAT_CHANNEL_ID=
AMOCRM_CHAT_SECRET_KEY=

# --- Advertising (38-ФЗ о рекламе) ---
ADVERTISING_ERID=
ADVERTISING_INN=

# --- PII Proxy + Encryption (152-ФЗ) ---
PII_PROXY_ENABLED=true
# PII_ENCRYPTION_KEY=          # 64-символ hex (openssl rand -hex 32), опционально
# LLM_AUDIT_HMAC_KEY=          # произвольный секрет для audit log, опционально

# --- DMS API ---
DMS_BASE_URL=https://proxy.hss.center
DMS_USERNAME=
DMS_PASSWORD=

# --- Escalation ---
MANAGER_TELEGRAM_CHAT_ID=
DASHBOARD_API_KEY=
FRONTEND_URL=https://edpalm-eurika.vercel.app
